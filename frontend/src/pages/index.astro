---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AgroVisión — Plataforma Agronómica</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css" />
    <style is:inline>
      body { background-color: #faf9f6; }
      .tab-content { display: none; animation: fadeIn 0.25s ease-in-out forwards; }
      .tab-content.active { display: block; }
      @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
      .nav-btn-active { background-color: #15803d; color: #fff !important; box-shadow: 0 4px 6px -1px rgba(21,128,61,.2); }
      
      /* Sidebar: control de transición de ancho suave */
      #sidebar {
        transition: width 0.3s ease-in-out;
        width: 4rem; /* Colapsado por defecto (w-16) */
      }
      #sidebar.expanded {
        width: 16rem; /* Expandido (w-64) */
      }
      #sidebar:not(.expanded) .sidebar-text {
        display: none;
      }
      #sidebar:not(.expanded) .nav-btn {
        justify-content: center;
        padding-left: 0;
        padding-right: 0;
      }
      #sidebar:not(.expanded) .p-4,
      #sidebar:not(.expanded) .p-5 {
        justify-content: center;
      }
      #sidebar:not(.expanded) #btn-sidebar-toggle {
        margin-left: 0;
      }
      #sidebar:not(.expanded) #btn-footer {
        justify-content: center;
        padding-left: 0;
        padding-right: 0;
      }
      #sidebar:not(.expanded) #btn-footer span,
      #sidebar:not(.expanded) #footer-chevron {
        display: none;
      }
      #sidebar:not(.expanded) #btn-profile-menu {
        justify-content: center;
        padding-left: 0;
        padding-right: 0;
      }
      #sidebar:not(.expanded) #btn-profile-menu div:not(#avatar-circle),
      #sidebar:not(.expanded) #btn-profile-menu i {
        display: none;
      }
      #sidebar:not(.expanded) #db-status {
        justify-content: center;
      }
      #sidebar:not(.expanded) #db-status-text,
      #sidebar:not(.expanded) #btn-telemetry {
        display: none;
      }
      #sidebar:not(.expanded) #profile-dropdown {
        left: calc(100% + 0.5rem);
        bottom: 0.5rem;
        right: auto;
        width: 14rem;
      }
    </style>
  </head>

  <body class="h-screen overflow-hidden text-stone-900 flex">
    <!-- Notificación flotante -->
    <div
      id="notif"
      class="fixed top-4 right-4 bg-stone-900 text-stone-100 px-5 py-3 rounded-xl shadow-2xl transition-all duration-300 translate-x-[150%] z-50 max-w-xs border border-stone-700"
    >
      <p class="font-bold text-sm" id="notif-title">Notificación</p>
      <p class="text-xs text-stone-300 mt-0.5" id="notif-body"></p>
    </div>

    <!-- Contenedor para aviso de credenciales faltantes (Fase 15) -->
    <div id="creds-toast-warning" class="fixed top-20 right-4 z-50 max-w-sm hidden"></div>

    <!-- SECCIÓN 1: SIDEBAR COLAPSABLE -->
    <aside
      id="sidebar"
      class="flex-shrink-0 bg-stone-900 text-stone-200 flex flex-col z-30 border-r border-stone-800 h-full"
    >
      <div class="p-4 border-b border-stone-800 flex items-center justify-between">
        <div class="flex items-center gap-2 overflow-hidden">
          <i class="fa-solid fa-seedling text-emerald-500 text-2xl shrink-0"></i>
          <div class="sidebar-text">
            <h1 class="text-lg font-bold text-emerald-500 tracking-wide">AgroVisión</h1>
          </div>
        </div>
        <button
          id="btn-sidebar-toggle"
          class="text-stone-500 hover:text-white p-1"
          title="Alternar Sidebar"
        >
          <i class="fa-solid fa-bars" id="toggle-icon"></i>
        </button>
      </div>

      <nav class="flex-1 p-4 space-y-2 overflow-y-auto" id="main-nav">
        <button data-tab="tab-resumen" class="nav-btn nav-btn-active w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-stone-400 hover:bg-stone-800 hover:text-white transition-all">
          <i class="fa-solid fa-house w-5 text-center"></i>
          <span class="sidebar-text">Resumen</span>
        </button>
        <button data-tab="tab-satelite" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-stone-400 hover:bg-stone-800 hover:text-white transition-all">
          <i class="fa-solid fa-satellite-dish w-5 text-center"></i>
          <span class="sidebar-text">Teledetección</span>
        </button>
        <button data-tab="tab-weather" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-stone-400 hover:bg-stone-800 hover:text-white transition-all">
          <i class="fa-solid fa-cloud w-5 text-center"></i>
          <span class="sidebar-text">Meteorología</span>
        </button>
        <button data-tab="tab-analysis" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-stone-400 hover:bg-stone-800 hover:text-white transition-all">
          <i class="fa-solid fa-chart-line w-5 text-center"></i>
          <span class="sidebar-text">Análisis Cruzado</span>
        </button>
        <button data-tab="tab-vision" class="nav-btn w-full flex items-center justify-between gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-stone-400 hover:bg-stone-800 hover:text-white transition-all">
          <span class="flex items-center gap-3"><i class="fa-solid fa-helicopter w-5 text-center"></i><span class="sidebar-text">Conteo</span></span>
          <span class="bg-amber-500/10 text-amber-400 text-[8px] font-bold px-1.5 py-0.5 rounded border border-amber-500/20 uppercase sidebar-text shrink-0">Standby</span>
        </button>
      </nav>

      <!-- Footer plegable -->
      <div class="border-t border-stone-800 bg-stone-950/50 relative">
        <button id="btn-footer" class="w-full flex items-center justify-between px-4 py-2 text-[10px] text-stone-500 uppercase tracking-widest">
          <span>Estado de sesión</span><i id="footer-chevron" class="fa-solid fa-chevron-up"></i>
        </button>
        <div id="footer-body" class="p-4 pt-0">
          <div id="btn-profile-menu" class="flex items-center gap-3 cursor-pointer hover:bg-stone-800/50 p-1.5 rounded-lg transition-all">
            <div class="w-8 h-8 rounded-full bg-emerald-700 flex items-center justify-center text-xs font-bold text-white shrink-0" id="avatar-circle">AG</div>
            <div class="truncate">
              <h5 class="text-xs font-semibold text-stone-200" id="user-display-name">Agrónomo</h5>
              <p class="text-[9px] text-stone-500" id="user-session-mode">Sesión efímera (BYOK)</p>
            </div>
            <i class="fa-solid fa-ellipsis-vertical text-stone-500 ml-auto"></i>
          </div>

          <!-- Menu Dropdown de Perfil -->
          <div id="profile-dropdown" class="hidden absolute bottom-full left-4 right-4 mb-2 bg-stone-900 border border-stone-800 rounded-xl shadow-xl z-50 p-2 space-y-1">
            <button data-action="tab-settings" class="dropdown-btn w-full text-left flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-semibold text-stone-300 hover:bg-stone-800 hover:text-white transition-all">
              <i class="fa-solid fa-user-gear text-stone-500 w-4"></i> Ajustes de Perfil
            </button>
            <button data-action="tab-config" class="dropdown-btn w-full text-left flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-semibold text-stone-300 hover:bg-stone-800 hover:text-white transition-all">
              <i class="fa-solid fa-sliders text-stone-500 w-4"></i> Credenciales & APIs
            </button>
            <button data-action="tab-data" class="dropdown-btn w-full text-left flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-semibold text-stone-300 hover:bg-stone-800 hover:text-white transition-all">
              <i class="fa-solid fa-database text-stone-500 w-4"></i> Explorador de Datos
            </button>
            <button id="dropdown-telemetry" class="w-full text-left flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-semibold text-stone-300 hover:bg-stone-800 hover:text-white transition-all">
              <i class="fa-solid fa-chart-line text-stone-500 w-4"></i> Telemetría de UI
            </button>
            <hr class="border-stone-800 my-1" />
            <button id="dropdown-logout" class="w-full text-left flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-semibold text-red-400 hover:bg-red-950/20 hover:text-red-300 transition-all">
              <i class="fa-solid fa-right-from-bracket w-4"></i> Cerrar Sesión
            </button>
          </div>

          <div class="mt-3 flex items-center gap-2 text-[10px]" id="db-status">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-stone-500 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-stone-500"></span>
            </span>
            <span id="db-status-text" class="text-stone-400">Conectando al backend…</span>
            <button id="btn-telemetry" class="ml-auto text-stone-500 hover:text-emerald-400 transition-colors" title="Ver telemetría">
              <i class="fa-solid fa-chart-line text-[10px]"></i>
            </button>
          </div>
        </div>
      </div>
    </aside>

    <!-- MAIN BODY CONTENEDOR (SECCIÓN 2 + SECCIÓN 3) -->
    <main id="main" class="flex-1 flex overflow-hidden h-full">
      
      <!-- SECCIÓN 2: PANEL CENTRAL DE AJUSTES Y CHAT (w-96 FIJO) -->
      <div id="panel-middle" class="w-96 flex-shrink-0 border-r border-stone-200 bg-white flex flex-col h-full overflow-hidden">
        <!-- Header con botón de branding central -->
        <div class="bg-stone-50 border-b border-stone-200 px-4 py-3 flex items-center justify-between shrink-0">
          <div class="flex items-center gap-1.5">
            <label class="text-[10px] font-bold text-stone-600 uppercase" for="select-parcela">Parcela:</label>
            <select id="select-parcela" class="text-xs border border-stone-300 rounded p-1.5 bg-white font-semibold focus:outline-none focus:border-emerald-600 max-w-[120px]">
              <option value="">(sin parcelas)</option>
            </select>
          </div>
          
          <!-- Botón de branding central -->
          <button id="btn-branding-toggle" class="w-9 h-9 rounded-full bg-emerald-700 text-white flex items-center justify-center shadow hover:bg-emerald-800 transition-all" title="Mostrar Chat con Asistente">
            <i class="fa-solid fa-robot text-base" id="branding-icon"></i>
          </button>
          
          <div class="text-right">
            <span class="text-[9px] text-stone-500 font-bold block uppercase leading-none">Activa</span>
            <span id="active-parcel-name-display" class="text-xs font-bold text-stone-800 truncate block max-w-[100px]">—</span>
          </div>
        </div>

        <!-- Vista 1: Formulario de 10 Atributos de Ajustes de Parcela (Visible por defecto) -->
        <div id="section2-form" class="flex-grow overflow-y-auto p-4 space-y-4">
          <h3 class="font-bold text-sm text-stone-800 flex items-center gap-2">
            <i class="fa-solid fa-sliders text-emerald-600"></i> Ajustes de Parcela
          </h3>
          <form id="parcel-attributes-form" class="space-y-3 text-xs" onsubmit="event.preventDefault();">
            <div>
              <label class="block text-[10px] font-bold text-stone-600 uppercase mb-0.5">Variedad de Cultivo</label>
              <input type="text" id="attr-crop-variety" class="w-full p-2 border border-stone-300 rounded bg-stone-50 focus:ring-1 focus:ring-emerald-500" placeholder="Ej: Arándano Biloxi" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-stone-600 uppercase mb-0.5">Tipo de Campo</label>
              <input type="text" id="attr-field-type" class="w-full p-2 border border-stone-300 rounded bg-stone-50 focus:ring-1 focus:ring-emerald-500" placeholder="Ej: Valle / Ladera" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-stone-600 uppercase mb-0.5">Tipo de Suelo</label>
              <input type="text" id="attr-soil-type" class="w-full p-2 border border-stone-300 rounded bg-stone-50 focus:ring-1 focus:ring-emerald-500" placeholder="Ej: Franco-arenoso" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-stone-600 uppercase mb-0.5">Sistema de Riego</label>
              <input type="text" id="attr-irrigation-system" class="w-full p-2 border border-stone-300 rounded bg-stone-50 focus:ring-1 focus:ring-emerald-500" placeholder="Ej: Goteo automatizado" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-stone-600 uppercase mb-0.5">Plagas / Enfermedades</label>
              <input type="text" id="attr-pests-diseases" class="w-full p-2 border border-stone-300 rounded bg-stone-50 focus:ring-1 focus:ring-emerald-500" placeholder="Ej: Mosca de la fruta" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-stone-600 uppercase mb-0.5">Fecha de Plantación</label>
              <input type="date" id="attr-plantation-date" class="w-full p-2 border border-stone-300 rounded bg-stone-50 focus:ring-1 focus:ring-emerald-500" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-stone-600 uppercase mb-0.5">Número de Plantas</label>
              <input type="number" id="attr-num-plants" class="w-full p-2 border border-stone-300 rounded bg-stone-50 focus:ring-1 focus:ring-emerald-500" placeholder="Ej: 1250" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-stone-600 uppercase mb-0.5">Rendimiento Histórico</label>
              <input type="text" id="attr-historical-yield" class="w-full p-2 border border-stone-300 rounded bg-stone-50 focus:ring-1 focus:ring-emerald-500" placeholder="Ej: 15 Tn/Ha" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-stone-600 uppercase mb-0.5">Mercado Objetivo</label>
              <input type="text" id="attr-target-market" class="w-full p-2 border border-stone-300 rounded bg-stone-50 focus:ring-1 focus:ring-emerald-500" placeholder="Ej: Exportación EE.UU." />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-stone-600 uppercase mb-0.5">Metadatos del Documento</label>
              <textarea id="attr-document-metadata" rows="2" class="w-full p-2 border border-stone-300 rounded bg-stone-50 focus:ring-1 focus:ring-emerald-500" placeholder="Ej: Contrato de arrendamiento #1024"></textarea>
            </div>
            <div class="pt-2">
              <button id="btn-save-attributes" class="w-full bg-emerald-700 hover:bg-emerald-800 text-white font-bold p-2.5 rounded transition-all flex items-center justify-center gap-2">
                <i class="fa-solid fa-floppy-disk"></i> Guardar Ajustes
              </button>
            </div>
          </form>
        </div>

        <!-- Vista 2: Chat Assistant (Oculto por defecto) -->
        <div id="section2-chat" class="hidden flex-1 flex flex-col h-full bg-stone-50">
          <div class="bg-stone-900 text-white px-4 py-2 flex items-center justify-between shrink-0">
            <span class="w-2.5 h-2.5 bg-emerald-500 rounded-full animate-pulse"></span>
            <h4 class="font-bold text-[10px] font-mono">agrovision_agent (Llama-3)</h4>
            <span class="text-[8px] text-stone-400">Contexto Sincronizado</span>
          </div>
          <div id="chat-history" class="flex-1 p-3 overflow-y-auto space-y-3 text-xs">
            <p class="text-stone-500">Pregúntame sobre el NDVI, el clima o la densidad de tus parcelas.</p>
          </div>
          <div class="p-2 border-t border-stone-200 bg-white flex gap-1.5 shrink-0">
            <input id="chat-input" type="text" placeholder="Preguntar al asistente..." class="flex-grow p-2 border border-stone-300 rounded text-xs focus:outline-none focus:ring-1 focus:ring-emerald-500" />
            <button id="btn-chat" class="bg-stone-900 hover:bg-stone-800 text-white font-bold px-3 py-2 rounded text-xs">Enviar</button>
          </div>
        </div>
      </div>

      <!-- SECCIÓN 3: PANEL DERECHO DINÁMICO (TAB CONTENTS) -->
      <div id="panel-right" class="flex-grow overflow-y-auto bg-stone-50 h-full p-5 md:p-8">
        
        <!-- RESUMEN (MAPA PRINCIPAL A PANTALLA COMPLETA CON WIDGET FLOTANTE) -->
        <section id="tab-resumen" class="tab-content active h-full w-full relative flex flex-col">
          <div class="relative flex-1 w-full h-full min-h-[550px]">
            <div id="map" class="w-full h-full rounded-2xl border border-stone-200 shadow-sm" style="height: calc(100vh - 7rem);"></div>

            <!-- Botón del Selector de Parcelas (Widget Flotante) -->
            <div class="absolute top-4 left-4 z-[1000] flex flex-col items-start gap-2">
              <button id="btn-farm-selector-toggle" class="bg-stone-900/95 backdrop-blur text-stone-200 hover:text-white px-4 py-2.5 rounded-xl shadow-lg border border-stone-800 text-xs font-bold flex items-center gap-2 transition-all">
                <i class="fa-solid fa-leaf text-emerald-500"></i>
                <span id="current-farm-name">Seleccionar Parcela</span>
                <i class="fa-solid fa-chevron-down text-stone-500 text-[10px]"></i>
              </button>

              <!-- Panel Flotante desplegable -->
              <div id="farm-selector-dropdown" class="hidden w-72 bg-stone-950/95 backdrop-blur border border-stone-800 rounded-2xl shadow-2xl p-4 text-stone-200 space-y-4">
                <!-- Info de usuario del perfil -->
                <div class="flex items-center gap-2.5 pb-3 border-b border-stone-800/80">
                  <div class="w-9 h-9 rounded-full bg-emerald-700 flex items-center justify-center text-xs font-bold text-white shrink-0" id="floating-avatar">AG</div>
                  <div class="truncate">
                    <h5 class="text-xs font-semibold text-stone-200" id="floating-user-name">Agrónomo</h5>
                    <p class="text-[9px] text-stone-500" id="floating-user-email">alexprieto1997@gmail.com</p>
                  </div>
                </div>

                <!-- Vista 1: Selector de Parcelas -->
                <div id="farm-view-selector" class="space-y-3">
                  <h4 class="text-[10px] font-bold text-stone-500 uppercase tracking-wider">Nombre de la Parcela</h4>
                  
                  <!-- Listado de parcelas con radio selector + gear -->
                  <div class="space-y-1 max-h-48 overflow-y-auto pr-1" id="floating-parcelas-list">
                    <!-- Dinámico -->
                  </div>

                  <button id="btn-floating-add-parcel" class="w-full text-left flex items-center gap-2 text-xs font-bold text-emerald-400 hover:text-emerald-300 py-1 transition-colors mt-2">
                    <i class="fa-solid fa-plus text-xs"></i> Agregar Nueva Parcela
                  </button>
                </div>

                <!-- Vista 2: Crear Nueva Parcela (Formulario en flotante) -->
                <div id="farm-view-creator" class="hidden space-y-3">
                  <h4 class="text-[10px] font-bold text-stone-500 uppercase tracking-wider">Crear Nueva Parcela</h4>
                  <p class="text-[10px] text-stone-400 leading-relaxed">Dibuja el polígono sobre el mapa, ponle un nombre y guárdalo.</p>
                  
                  <div>
                    <label class="block text-[9px] font-bold text-stone-500 uppercase mb-1" for="floating-parcela-name">Nombre de Parcela</label>
                    <input id="floating-parcela-name" type="text" placeholder="Lote Norte (Uva)" class="w-full text-xs p-2 border border-stone-800 rounded bg-stone-900 text-stone-200 focus:outline-none focus:ring-1 focus:ring-emerald-500 animate-none" />
                  </div>

                  <div class="space-y-1.5 pt-1">
                    <button id="btn-floating-save-parcela" class="w-full bg-emerald-700 hover:bg-emerald-800 text-white font-bold text-xs p-2 rounded transition-all flex items-center justify-center gap-1.5">
                      <i class="fa-solid fa-floppy-disk"></i> Guardar Parcela
                    </button>
                    <button id="btn-floating-demo" class="w-full bg-stone-900 hover:bg-stone-800 text-stone-300 border border-stone-800 font-bold text-xs p-2 rounded transition-all flex items-center justify-center gap-1.5">
                      <i class="fa-solid fa-mountain-sun"></i> Cargar Parcela Demo
                    </button>
                    <button id="btn-floating-cancel-create" class="w-full text-center text-stone-500 hover:text-stone-300 text-[10px] py-1">
                      Cancelar
                    </button>
                  </div>
                </div>

              </div>
            </div>

          </div>
        </section>

        <!-- TELEDETECCIÓN (GIS + HEATMAPS + SATÉLITE) -->
        <section id="tab-satelite" class="tab-content space-y-6">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-bold text-stone-800 flex items-center gap-2">
              <i class="fa-solid fa-satellite-dish text-emerald-600"></i> Teledetección Espectral (GIS)
            </h3>
            <button class="btn-volver-mapa text-xs font-semibold px-3 py-1.5 bg-stone-200 hover:bg-stone-300 rounded-lg text-stone-700 transition-colors">
              <i class="fa-solid fa-arrow-left mr-1"></i> Volver al Mapa
            </button>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <div class="bg-white p-4 rounded-xl border border-stone-200 shadow-sm lg:col-span-5 flex flex-col">
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-bold text-sm text-stone-800">Mapa de calor (Heatmap)</h3>
                <button id="btn-heatmap" class="text-[11px] bg-emerald-700 hover:bg-emerald-800 text-white px-2 py-1 rounded font-bold"><i class="fa-solid fa-fire"></i> Generar Heatmap</button>
              </div>
              <div id="heatmap-box" class="flex-1 min-h-[300px] bg-stone-100 rounded-lg border border-stone-200 flex items-center justify-center text-xs text-stone-500">
                Pulsa «Generar Heatmap» para cargar el índice en el mapa de calor.
              </div>
              <div class="mt-3 h-3 w-full rounded" style="background:linear-gradient(to right,#a50026,#f46d43,#fee08b,#d9ef8b,#66bd63,#006837);"></div>
              <div class="flex justify-between text-[10px] font-mono text-stone-500"><span>-1</span><span>0</span><span>+1</span></div>
            </div>
            <div class="bg-white p-4 rounded-xl border border-stone-200 shadow-sm lg:col-span-7">
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-bold text-sm text-stone-800">Serie Temporal de Índices</h3>
                <div class="flex items-center gap-2">
                  <select id="select-index" class="text-[11px] border border-stone-300 rounded-lg p-1.5 bg-stone-50 font-semibold focus:outline-none focus:border-emerald-600">
                    <option value="ndvi">NDVI — Salud vegetal</option>
                    <option value="evi">EVI — Vegetación densa</option>
                    <option value="savi">SAVI — Suelo desnudo</option>
                    <option value="ndwi">NDWI — Agua/humedad</option>
                    <option value="ndre">NDRE — Clorofila/N</option>
                  </select>
