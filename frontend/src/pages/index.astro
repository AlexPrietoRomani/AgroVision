---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AgroVisión — Plataforma Agronómica</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css" />
    <style is:inline>
      body { background-color: #faf9f6; }
      .tab-content { display: none; animation: fadeIn 0.25s ease-in-out forwards; }
      .tab-content.active { display: block; }
      @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
      .nav-btn-active { background-color: #15803d; color: #fff !important; box-shadow: 0 4px 6px -1px rgba(21,128,61,.2); }
      #map, #map-readonly { height: 340px; border-radius: 0.5rem; z-index: 0; }
      /* Sidebar: control de visibilidad con la propiedad `transform` (Tailwind v4 usa
         la propiedad `translate`, que no se puede cancelar con transform inline). */
      #sidebar { transform: translateX(-100%); transition: transform 0.3s ease; }
      #sidebar.is-open { transform: translateX(0); }
      @media (min-width: 768px) {
        #sidebar { transform: translateX(0); }
        #sidebar.is-collapsed { transform: translateX(-100%); }
      }
    </style>
  </head>

  <body class="h-screen overflow-hidden text-stone-900">
    <!-- Notificación flotante -->
    <div
      id="notif"
      class="fixed top-4 right-4 bg-stone-900 text-stone-100 px-5 py-3 rounded-xl shadow-2xl transition-all duration-300 translate-x-[150%] z-50 max-w-xs border border-stone-700"
    >
      <p class="font-bold text-sm" id="notif-title">Notificación</p>
      <p class="text-xs text-stone-300 mt-0.5" id="notif-body"></p>
    </div>

    <!-- Botón hamburguesa (móvil): abre el sidebar -->
    <button
      id="btn-hamburger"
      class="md:hidden fixed top-3 left-3 z-40 bg-stone-900 text-white w-10 h-10 rounded-lg shadow-lg"
      aria-label="Abrir menú"
    >
      <i class="fa-solid fa-bars"></i>
    </button>
    <!-- Botón reabrir (desktop, cuando el sidebar está plegado) -->
    <button
      id="btn-reopen"
      class="hidden fixed top-3 left-3 z-40 bg-stone-900 text-white w-10 h-10 rounded-lg shadow-lg"
      aria-label="Mostrar menú"
    >
      <i class="fa-solid fa-bars"></i>
    </button>
    <!-- Backdrop (móvil) -->
    <div id="backdrop" class="fixed inset-0 bg-black/40 z-20 hidden md:hidden"></div>

    <!-- SIDEBAR -->
    <aside
      id="sidebar"
      class="fixed inset-y-0 left-0 w-72 bg-stone-900 text-stone-200 flex flex-col z-30 border-r border-stone-800"
    >
      <div class="p-5 border-b border-stone-800 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-emerald-500 tracking-wide flex items-center gap-2">
            <i class="fa-solid fa-seedling"></i> AgroVisión
          </h1>
          <p class="text-[10px] text-stone-400 uppercase tracking-widest mt-1">
            Plataforma Agronómica
          </p>
        </div>
        <button
          id="btn-collapse"
          class="hidden md:block text-stone-500 hover:text-white"
          title="Plegar"
        >
          <i class="fa-solid fa-angles-left"></i>
        </button>
      </div>

      <nav class="flex-1 p-4 space-y-2 overflow-y-auto" id="main-nav">
        <button data-tab="tab-resumen" class="nav-btn nav-btn-active w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-stone-400 hover:bg-stone-800 hover:text-white transition-all">
          <i class="fa-solid fa-chart-pie w-5"></i> Resumen de Campo
        </button>
        <button data-tab="tab-parcelas" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-stone-400 hover:bg-stone-800 hover:text-white transition-all">
          <i class="fa-solid fa-draw-polygon w-5"></i> Creación de Parcelas
        </button>
        <button data-tab="tab-satelite" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-stone-400 hover:bg-stone-800 hover:text-white transition-all">
          <i class="fa-solid fa-satellite-dish w-5"></i> Teledetección (GIS)
        </button>
        <button data-tab="tab-vision" class="nav-btn w-full flex items-center justify-between gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-stone-400 hover:bg-stone-800 hover:text-white transition-all">
          <span class="flex items-center gap-3"><i class="fa-solid fa-helicopter w-5"></i> Detección Dron</span>
          <span class="bg-amber-500/10 text-amber-400 text-[8px] font-bold px-1.5 py-0.5 rounded border border-amber-500/20 uppercase">En desarrollo</span>
        </button>
        <button data-tab="tab-chat" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-stone-400 hover:bg-stone-800 hover:text-white transition-all">
          <i class="fa-solid fa-robot w-5"></i> Asistente Agéntico
        </button>
        <button data-tab="tab-data" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-stone-400 hover:bg-stone-800 hover:text-white transition-all">
          <i class="fa-solid fa-database w-5"></i> Explorador de Datos
        </button>
        <button data-tab="tab-config" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-stone-400 hover:bg-stone-800 hover:text-white transition-all">
          <i class="fa-solid fa-sliders w-5"></i> Credenciales & APIs
        </button>
      </nav>

      <!-- Footer plegable -->
      <div class="border-t border-stone-800 bg-stone-950/50">
        <button id="btn-footer" class="w-full flex items-center justify-between px-4 py-2 text-[10px] text-stone-500 uppercase tracking-widest">
          <span>Estado de sesión</span><i id="footer-chevron" class="fa-solid fa-chevron-up"></i>
        </button>
        <div id="footer-body" class="p-4 pt-0">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-emerald-700 flex items-center justify-center text-xs font-bold text-white">AG</div>
            <div>
              <h5 class="text-xs font-semibold text-stone-200">Agrónomo</h5>
              <p class="text-[9px] text-stone-500">Sesión efímera (BYOK)</p>
            </div>
          </div>
          <div class="mt-3 flex items-center gap-2 text-[10px]" id="db-status">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-stone-500 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-stone-500"></span>
            </span>
            <span id="db-status-text" class="text-stone-400">Conectando al backend…</span>
            <button id="btn-telemetry" class="ml-auto text-stone-500 hover:text-emerald-400 transition-colors" title="Ver telemetría">
              <i class="fa-solid fa-chart-line text-[10px]"></i>
            </button>
          </div>
        </div>
      </div>
    </aside>

    <!-- MAIN -->
    <main id="main" class="h-full overflow-y-auto flex flex-col bg-stone-50 md:ml-72 transition-[margin] duration-300">
      <header class="bg-white border-b border-stone-200 px-6 md:px-8 py-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 shrink-0">
        <div id="titlebox" class="pl-12 md:pl-0">
          <h2 id="header-title" class="text-lg font-bold text-stone-800">Resumen de Campo</h2>
          <p id="header-desc" class="text-xs text-stone-500">Visión analítica unificada de parcelas.</p>
        </div>
        <div class="flex items-center gap-3">
          <label class="text-xs font-bold text-stone-600" for="select-parcela">Parcela:</label>
          <select id="select-parcela" class="text-xs border border-stone-300 rounded-lg p-2 bg-stone-50 font-semibold focus:outline-none focus:border-emerald-600 min-w-[180px]">
            <option value="">(sin parcelas)</option>
          </select>
        </div>
      </header>

      <div class="flex-1 p-5 md:p-8 overflow-y-auto">
        <!-- RESUMEN -->
        <section id="tab-resumen" class="tab-content active space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm flex items-center gap-4">
              <div class="p-3 bg-emerald-100 text-emerald-800 rounded-lg text-xl"><i class="fa-solid fa-leaf"></i></div>
              <div><span class="text-xs text-stone-500 font-bold block">NDVI (último)</span><span id="kpi-ndvi" class="text-2xl font-bold text-stone-800">—</span></div>
            </div>
            <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm flex items-center gap-4">
              <div class="p-3 bg-blue-100 text-blue-800 rounded-lg text-xl"><i class="fa-solid fa-arrow-trend-up"></i></div>
              <div><span class="text-xs text-stone-500 font-bold block">Tendencia NDVI</span><span id="kpi-trend" class="text-2xl font-bold text-stone-800">—</span></div>
            </div>
            <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm flex items-center gap-4">
              <div class="p-3 bg-amber-100 text-amber-800 rounded-lg text-xl"><i class="fa-solid fa-ruler-combined"></i></div>
              <div><span class="text-xs text-stone-500 font-bold block">Área</span><span id="kpi-area" class="text-2xl font-bold text-stone-800">—</span></div>
            </div>
            <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm flex items-center gap-4">
              <div class="p-3 bg-purple-100 text-purple-800 rounded-lg text-xl"><i class="fa-solid fa-seedling"></i></div>
              <div><span class="text-xs text-stone-500 font-bold block">Densidad</span><span class="text-sm font-bold text-stone-500">en desarrollo</span></div>
            </div>
          </div>
          <div class="bg-white p-6 rounded-xl border border-stone-200 shadow-sm">
            <h3 class="font-bold text-sm text-stone-800 mb-4">Evolución NDVI del lote activo</h3>
            <canvas id="chart-resumen" height="110"></canvas>
            <p id="resumen-empty" class="text-xs text-stone-500 mt-2">Selecciona una parcela para ver su evolución.</p>
          </div>
        </section>

        <!-- CREACIÓN DE PARCELAS -->
        <section id="tab-parcelas" class="tab-content space-y-6">
          <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm text-sm text-stone-600">
            Dibuja el polígono de tu parcela sobre el mapa (EPSG:4326), nómbrala y guárdala. Al guardar se dispara el <strong>backfill NDVI de 5 años</strong>.
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm lg:col-span-7">
              <h3 class="font-bold text-sm text-stone-800 mb-3">Delimitador de Parcelas</h3>
              <div id="map"></div>
            </div>
            <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm lg:col-span-5 flex flex-col">
              <h3 class="font-bold text-sm text-stone-800 mb-3">Guardar Parcela</h3>
              <label class="block text-xs font-bold text-stone-600 mb-1" for="parcela-name">Nombre</label>
              <input id="parcela-name" type="text" placeholder="Lote Sur (Arándano - 12 Ha)" class="w-full text-xs p-3 border border-stone-300 rounded-lg bg-stone-50 mb-3 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
              <button id="btn-save-parcela" class="w-full bg-emerald-700 hover:bg-emerald-800 text-white font-bold text-xs px-4 py-3 rounded-lg transition-all flex items-center justify-center gap-2">
                <i class="fa-solid fa-floppy-disk"></i> Guardar y disparar backfill
              </button>
              <button id="btn-demo" class="w-full mt-2 bg-stone-100 hover:bg-stone-200 text-stone-800 font-bold text-xs px-4 py-2 rounded-lg transition-all flex items-center justify-center gap-2">
                <i class="fa-solid fa-mountain-sun"></i> Cargar parcela demo (Lomas de Lachay)
              </button>
              <h4 class="font-bold text-xs text-stone-800 mt-5 mb-2">Parcelas registradas</h4>
              <ul id="parcelas-list" class="space-y-2 text-xs"></ul>
            </div>
          </div>
        </section>

        <!-- TELEDETECCIÓN -->
        <section id="tab-satelite" class="tab-content space-y-6">
          <div class="bg-white p-6 rounded-xl border border-stone-200 shadow-sm">
            <h3 class="text-base font-bold text-stone-800 mb-2">Teledetección (solo lectura)</h3>
            <p class="text-sm text-stone-600 leading-relaxed">
              Serie <strong>mensual de 5 años</strong> (Sentinel-2) vs. clima (Open-Meteo) para la parcela seleccionada. El heatmap tiene resolución ~10 m/px. <em>El dibujo está en «Creación de Parcelas».</em>
            </p>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm lg:col-span-5 flex flex-col">
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-bold text-sm text-stone-800">Mapa de calor</h3>
                <button id="btn-heatmap" class="text-[11px] bg-stone-100 hover:bg-stone-200 text-stone-800 px-2 py-1 rounded font-bold"><i class="fa-solid fa-fire"></i> Generar</button>
              </div>
              <div id="heatmap-box" class="flex-1 min-h-[300px] bg-stone-100 rounded-lg border border-stone-200 flex items-center justify-center text-xs text-stone-500">
                Pulsa «Generar» para ver el heatmap de la parcela.
              </div>
              <div class="mt-3 h-3 w-full rounded" style="background:linear-gradient(to right,#a50026,#f46d43,#fee08b,#d9ef8b,#66bd63,#006837);"></div>
              <div class="flex justify-between text-[10px] font-mono text-stone-500"><span>-1</span><span>0</span><span>+1</span></div>
            </div>
            <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm lg:col-span-7">
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-bold text-sm text-stone-800">Índice espectral vs. Clima — últimos 5 años (mensual)</h3>
                <div class="flex items-center gap-2">
                  <select id="select-index" class="text-[11px] border border-stone-300 rounded-lg p-1.5 bg-stone-50 font-semibold focus:outline-none focus:border-emerald-600">
                    <option value="ndvi">NDVI — Salud vegetal</option>
                    <option value="evi">EVI — Vegetación densa</option>
                    <option value="savi">SAVI — Suelo desnudo</option>
                    <option value="ndwi">NDWI — Agua/humedad</option>
                    <option value="ndre">NDRE — Clorofila/N</option>
                  </select>
                  <button id="btn-reprocess" class="text-[11px] bg-amber-100 hover:bg-amber-200 text-amber-800 px-2 py-1.5 rounded font-bold whitespace-nowrap"><i class="fa-solid fa-rotate"></i> Reprocesar</button>
                </div>
              </div>
              <canvas id="chart-satelite" height="150"></canvas>
              <p id="satelite-empty" class="text-xs text-stone-500 mt-2">Selecciona una parcela.</p>
            </div>
          </div>
        </section>

        <!-- DETECCIÓN DRON (EN DESARROLLO) -->
        <section id="tab-vision" class="tab-content space-y-6">
          <div class="bg-amber-50 border border-amber-300 text-amber-900 p-5 rounded-xl shadow-sm flex items-start gap-3">
            <i class="fa-solid fa-screwdriver-wrench text-amber-500 text-lg mt-0.5"></i>
            <div>
              <h4 class="font-bold text-sm">Módulo en desarrollo (standby)</h4>
              <p class="text-xs leading-relaxed mt-1">El conteo de plantas por dron aún <strong>no está activo</strong>. Se habilitará cuando el repo del modelo publique el artefacto <code>agrovision-plantcount</code> en Hugging Face Hub (<code>COUNTING_ENABLED=true</code>). La infraestructura (cola, worker, tabla) ya está creada e inactiva.</p>
            </div>
          </div>
        </section>

        <!-- ASISTENTE -->
        <section id="tab-chat" class="tab-content space-y-4">
          <div class="bg-white rounded-xl border border-stone-200 shadow-sm flex flex-col h-[60vh]">
            <div class="bg-stone-900 text-white px-5 py-3 flex items-center gap-3 rounded-t-xl">
              <span class="w-2.5 h-2.5 bg-emerald-500 rounded-full animate-pulse"></span>
              <h4 class="font-bold text-xs font-mono">agrovision_agent · Llama-3-70B (Groq)</h4>
            </div>
            <div id="chat-history" class="flex-1 p-5 overflow-y-auto space-y-3 bg-stone-50 text-xs">
              <p class="text-stone-500">Pregúntame sobre el NDVI, el clima o la densidad de tus parcelas.</p>
            </div>
            <div class="p-3 border-t border-stone-200 bg-white flex gap-2">
              <input id="chat-input" type="text" placeholder="¿Cómo evolucionó el NDVI de mi parcela?" class="flex-grow p-3 border border-stone-300 rounded-lg text-xs focus:outline-none focus:ring-2 focus:ring-emerald-500" />
              <button id="btn-chat" class="bg-stone-900 hover:bg-stone-800 text-white font-bold text-xs px-5 rounded-lg">Enviar</button>
            </div>
          </div>
        </section>

        <!-- EXPLORADOR DE DATOS (Fase 11) -->
        <section id="tab-data" class="tab-content space-y-6">
          <div class="bg-white p-6 rounded-xl border border-stone-200 shadow-sm">
            <h3 class="text-base font-bold text-stone-800 mb-2">Explorador de Datos</h3>
            <p class="text-sm text-stone-600 leading-relaxed">
              Consulta las tablas de tu base de datos Supabase directamente. Selecciona una tabla para ver sus registros o ejecuta consultas SQL personalizadas.
            </p>
          </div>
          <!-- Diagrama ER (full width) -->
          <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm">
            <h3 class="font-bold text-sm text-stone-800 mb-3">Diagrama Entidad-Relación</h3>
            <div id="er-diagram" class="w-full overflow-auto rounded-lg bg-stone-50 border border-stone-200">
              <p class="text-xs text-stone-500 p-3">Cargando esquema...</p>
            </div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <!-- Selector de tabla -->
            <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm lg:col-span-4">
              <h3 class="font-bold text-sm text-stone-800 mb-3">Tablas disponibles</h3>
              <div class="space-y-2" id="tables-list">
                <p class="text-xs text-stone-500">Cargando tablas...</p>
              </div>
            </div>
            <!-- Vista de datos -->
            <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm lg:col-span-8">
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-bold text-sm text-stone-800" id="data-view-title">Selecciona una tabla</h3>
                <span class="text-[10px] text-stone-500" id="data-view-count"></span>
              </div>
              <div id="data-view-content" class="overflow-x-auto max-h-[400px] overflow-y-auto">
                <p class="text-xs text-stone-500">Los datos aparecerán aquí.</p>
              </div>
            </div>
          </div>
          <!-- Consulta SQL personalizada -->
          <div class="bg-white p-5 rounded-xl border border-stone-200 shadow-sm">
            <h3 class="font-bold text-sm text-stone-800 mb-3">Consulta SQL personalizada</h3>
            <textarea id="sql-query" rows="4" placeholder="SELECT * FROM fields LIMIT 10;" class="w-full text-xs p-3 border border-stone-300 rounded-lg bg-stone-50 font-mono focus:outline-none focus:ring-2 focus:ring-emerald-500 mb-3"></textarea>
            <div class="flex gap-2">
              <button id="btn-run-query" class="bg-emerald-700 hover:bg-emerald-800 text-white font-bold text-xs px-4 py-2 rounded-lg">
                <i class="fa-solid fa-play"></i> Ejecutar
              </button>
              <button id="btn-clear-query" class="bg-stone-100 hover:bg-stone-200 text-stone-800 font-bold text-xs px-4 py-2 rounded-lg">
                <i class="fa-solid fa-eraser"></i> Limpiar
              </button>
            </div>
            <div id="query-result" class="mt-4 overflow-x-auto max-h-[300px] overflow-y-auto"></div>
          </div>
        </section>

        <!-- CREDENCIALES -->
        <section id="tab-config" class="tab-content space-y-6">
          <div id="creds-warning" class="bg-amber-50 border border-amber-300 text-amber-900 p-4 rounded-xl text-sm">
            ⚠️ <strong>Tus credenciales se usan solo en esta sesión. No se guardan ni almacenan.</strong> Si actualizas o cierras la página, todo se borrará.
          </div>
          <div id="creds-production-warning" class="hidden bg-red-50 border border-red-300 text-red-900 p-4 rounded-xl text-sm">
            🌐 <strong>Entorno de producción:</strong> Debes ingresar tus propias credenciales para usar la plataforma. Las credenciales del servidor no están disponibles en este entorno.
          </div>
          <div class="bg-white p-6 rounded-xl border border-stone-200 shadow-sm grid grid-cols-1 md:grid-cols-2 gap-5">
            <div><label class="block text-xs font-bold text-stone-600 mb-1">Groq API Key (asistente RAG)</label><input id="in-groq" type="password" placeholder="gsk_..." class="w-full text-xs p-3 border border-stone-300 rounded-lg bg-stone-50" /></div>
            <div><label class="block text-xs font-bold text-stone-600 mb-1">Copernicus Client ID</label><input id="in-copid" type="password" placeholder="sh-..." class="w-full text-xs p-3 border border-stone-300 rounded-lg bg-stone-50" /></div>
            <div><label class="block text-xs font-bold text-stone-600 mb-1">Copernicus Client Secret</label><input id="in-copsecret" type="password" class="w-full text-xs p-3 border border-stone-300 rounded-lg bg-stone-50" /></div>
            <div><label class="block text-xs font-bold text-stone-600 mb-1">Supabase URL</label><input id="in-sburl" type="text" placeholder="https://xxxx.supabase.co" class="w-full text-xs p-3 border border-stone-300 rounded-lg bg-stone-50" /></div>
            <div><label class="block text-xs font-bold text-stone-600 mb-1">Supabase anon key</label><input id="in-sbkey" type="password" class="w-full text-xs p-3 border border-stone-300 rounded-lg bg-stone-50" /></div>
            <div class="md:col-span-2 bg-stone-50 border border-stone-200 rounded-lg p-3 flex items-center justify-between gap-3">
              <span class="text-[11px] text-stone-600" id="env-status">¿Tienes un <code>.env</code> en el servidor (desarrollo local)? Úsalo sin reescribir las llaves.</span>
              <button id="btn-check-env" class="bg-stone-800 hover:bg-stone-700 text-white font-bold text-xs px-4 py-2 rounded-lg whitespace-nowrap"><i class="fa-solid fa-file-shield"></i> Revisar .env del servidor</button>
            </div>
            <div class="md:col-span-2 flex items-center justify-between pt-2 border-t border-stone-100">
              <span class="text-[11px] text-amber-600"><i class="fa-solid fa-triangle-exclamation"></i> <span id="creds-state">0 llaves activas (se borran al refrescar)</span></span>
              <button id="btn-save-creds" class="bg-emerald-700 hover:bg-emerald-800 text-white font-bold text-xs px-5 py-3 rounded-lg">Usar en esta sesión</button>
            </div>
          </div>
        </section>
      </div>
    </main>

    <!-- Modal de Telemetría (Fase 12) -->
    <div id="telemetry-modal" class="fixed inset-0 bg-black/60 z-50 hidden items-center justify-center p-4">
      <div class="bg-white rounded-xl shadow-2xl max-w-4xl w-full max-h-[80vh] flex flex-col">
        <div class="flex items-center justify-between px-5 py-3 border-b border-stone-200">
          <h3 class="font-bold text-sm text-stone-800"><i class="fa-solid fa-chart-line mr-2 text-emerald-600"></i>Telemetría de Sesión</h3>
          <button id="btn-close-telemetry" class="text-stone-400 hover:text-stone-700"><i class="fa-solid fa-xmark text-lg"></i></button>
        </div>
        <div class="flex-1 overflow-y-auto p-5">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-xs text-stone-500">Sesión:</span>
            <code class="text-[10px] bg-stone-100 px-2 py-1 rounded font-mono" id="telemetry-session-id"></code>
            <button id="btn-refresh-telemetry" class="ml-auto text-xs bg-stone-100 hover:bg-stone-200 text-stone-700 px-3 py-1 rounded font-semibold">
              <i class="fa-solid fa-rotate-right mr-1"></i>Actualizar
            </button>
          </div>
          <div id="telemetry-content" class="space-y-2">
            <p class="text-xs text-stone-500">Cargando eventos...</p>
          </div>
        </div>
        <div class="px-5 py-3 border-t border-stone-200 bg-stone-50 rounded-b-xl">
          <p class="text-[10px] text-stone-500">
            <i class="fa-solid fa-info-circle mr-1"></i>
            Los eventos se guardan en la BD si <code>EVENTS_PERSIST=true</code>. El buffer en memoria muestra los últimos 500 eventos de esta sesión.
          </p>
        </div>
      </div>
    </div>

    <!-- Modal de Reprocesar (SF13.1) -->
    <div id="reprocess-modal" class="fixed inset-0 bg-black/60 z-50 hidden items-center justify-center p-4">
      <div class="bg-white rounded-xl shadow-2xl max-w-md w-full p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-bold text-sm text-stone-800"><i class="fa-solid fa-rotate mr-2 text-amber-600"></i>Reprocesar datos</h3>
          <button id="btn-close-reprocess" class="text-stone-400 hover:text-stone-700"><i class="fa-solid fa-xmark text-lg"></i></button>
        </div>
        <p class="text-xs text-stone-600 mb-4">Recalcular datos históricos para la parcela seleccionada. Los datos existentes se sobrescribirán.</p>
        <div class="space-y-3 mb-5">
          <label class="flex items-center gap-3 p-3 border border-stone-200 rounded-lg hover:bg-stone-50 cursor-pointer">
            <input type="radio" name="reprocess-mode" value="indices" class="accent-emerald-600">
            <div><span class="text-sm font-semibold text-stone-800">Solo Sentinel-2</span><br><span class="text-[11px] text-stone-500">Recalcular NDVI, EVI, SAVI, NDWI y NDRE</span></div>
          </label>
          <label class="flex items-center gap-3 p-3 border border-stone-200 rounded-lg hover:bg-stone-50 cursor-pointer">
            <input type="radio" name="reprocess-mode" value="weather" class="accent-amber-600">
            <div><span class="text-sm font-semibold text-stone-800">Solo clima</span><br><span class="text-[11px] text-stone-500">Recargar datos climáticos (temp, HR, radiación, viento)</span></div>
          </label>
          <label class="flex items-center gap-3 p-3 border border-stone-200 rounded-lg hover:bg-stone-50 cursor-pointer">
            <input type="radio" name="reprocess-mode" value="all" checked class="accent-stone-600">
            <div><span class="text-sm font-semibold text-stone-800">Ambos</span><br><span class="text-[11px] text-stone-500">Reprocesar índices espectrales y recargar clima</span></div>
          </label>
        </div>
        <div class="flex gap-2 justify-end">
          <button id="btn-cancel-reprocess" class="text-xs bg-stone-100 hover:bg-stone-200 text-stone-700 px-4 py-2 rounded-lg font-semibold">Cancelar</button>
          <button id="btn-run-reprocess" class="text-xs bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg font-bold"><i class="fa-solid fa-play"></i> Ejecutar</button>
        </div>
        <div id="reprocess-status" class="hidden mt-3 text-xs text-stone-600"></div>
      </div>
    </div>

    <!-- Librerías CDN -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script is:inline src="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>

    <script is:inline>
      // ===== Estado EFÍMERO (solo memoria; se borra al refrescar) =====
      let creds = {};
      let parcels = [];
      let drawnGeojson = null;
      let map = null, drawnItems = null, parcelsLayer = null;
      let chartResumen = null, chartSatelite = null;
      const sessionId = "sess-" + Math.random().toString(36).slice(2);
      let backendOk = false;
      let appEnv = "development";

      const $ = (id) => document.getElementById(id);
      function authHeaders() {
        const h = {};
        if (creds.groq) h["X-User-Groq-Key"] = creds.groq;
        if (creds.copId) h["X-User-Copernicus-Id"] = creds.copId;
        if (creds.copSecret) h["X-User-Copernicus-Secret"] = creds.copSecret;
        if (creds.sbUrl) h["X-User-Supabase-Url"] = creds.sbUrl;
        if (creds.sbKey) h["X-User-Supabase-Key"] = creds.sbKey;
        return h;
      }
      function notify(title, body) {
        $("notif-title").innerText = title; $("notif-body").innerText = body || "";
        const n = $("notif"); n.classList.remove("translate-x-[150%]");
        setTimeout(() => n.classList.add("translate-x-[150%]"), 3500);
      }
      function updateStatus() {
        const el = $("db-status-text");
        const dot = $("db-status").querySelector("span.relative");
        if (!backendOk) {
          el.innerText = "Backend no disponible";
          el.className = "text-red-500";
          dot.className = "relative inline-flex rounded-full h-2 w-2 bg-red-500";
          return;
        }
        // Consultar al backend qué credenciales están disponibles (incluye DEV_* en desarrollo)
        fetch("./api/credentials/status")
          .then((r) => r.ok ? r.json() : null)
          .then((s) => {
            if (!s) {
              el.innerText = "Backend conectado · Status desconocido";
              el.className = "text-amber-400";
              dot.className = "relative inline-flex rounded-full h-2 w-2 bg-amber-500";
              return;
            }
            const missing = [];
            if (!s.groq) missing.push("Groq");
            if (!s.copernicus) missing.push("Copernicus");
            if (!s.supabase) missing.push("Supabase");
            if (missing.length === 0) {
              el.innerText = "Backend conectado · Todo OK";
              el.className = "text-emerald-400";
              dot.className = "relative inline-flex rounded-full h-2 w-2 bg-emerald-500";
            } else {
              el.innerText = `Backend conectado · Faltan: ${missing.join(", ")}`;
              el.className = "text-amber-400";
              dot.className = "relative inline-flex rounded-full h-2 w-2 bg-amber-500";
            }
          })
          .catch(() => {
            el.innerText = "Backend conectado · Error al verificar credenciales";
            el.className = "text-amber-400";
            dot.className = "relative inline-flex rounded-full h-2 w-2 bg-amber-500";
          });
      }
      // ===== Telemetría (Fase 9) =====
      // Envía un evento por cada acción del usuario al backend (POST /api/events).
      // Es "fire-and-forget": jamás bloquea ni rompe la UI. NUNCA mandar valores de
      // credenciales — solo metadatos (contadores, pestaña, status...).
      function track(action, meta = {}) {
        try {
          fetch("./api/events", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action, meta, session_id: sessionId, ts: new Date().toISOString() }),
            keepalive: true,
          }).catch(() => {});
        } catch { /* la telemetría nunca debe propagar errores */ }
      }
      // Errores globales no capturados (JS y promesas rechazadas).
      window.addEventListener("error", (e) => track("js_error", { message: String(e.message || e), where: "window" }));
      window.addEventListener("unhandledrejection", (e) => track("js_error", { message: String(e.reason || ""), where: "promise" }));

      async function api(path, opts = {}) {
        try {
          const res = await fetch("./api" + path, {
            ...opts,
            headers: { ...(opts.body ? { "Content-Type": "application/json" } : {}), ...authHeaders(), ...(opts.headers || {}) },
          });
          if (!res.ok) track("api_error", { where: path, status: res.status, method: opts.method || "GET" });
          return res;
        } catch (e) {
          track("api_error", { where: path, status: "network", method: opts.method || "GET" });
          throw e;
        }
      }

      // ===== Navegación (hash routing) =====
      const TITLES = {
        "tab-resumen": ["Resumen de Campo", "Visión analítica unificada de parcelas."],
        "tab-parcelas": ["Creación de Parcelas", "Dibuja y guarda polígonos (EPSG:4326)."],
        "tab-satelite": ["Teledetección (GIS)", "NDVI 5 años + clima + heatmap (solo lectura)."],
        "tab-vision": ["Detección por Dron", "Conteo de plantas — EN DESARROLLO."],
        "tab-chat": ["Asistente Agéntico", "Agente RAG sobre tus parcelas."],
        "tab-data": ["Explorador de Datos", "Consulta tus datos directamente (Fase 11)."],
        "tab-config": ["Credenciales & APIs", "Llaves efímeras (solo en esta sesión)."],
      };
      function switchTab(id) {
        document.querySelectorAll(".tab-content").forEach((s) => s.classList.remove("active"));
        document.querySelectorAll(".nav-btn").forEach((b) => b.classList.remove("nav-btn-active"));
        const sec = $(id); if (!sec) return;
        sec.classList.add("active");
        document.querySelector(`.nav-btn[data-tab="${id}"]`)?.classList.add("nav-btn-active");
        $("header-title").innerText = TITLES[id][0];
        $("header-desc").innerText = TITLES[id][1];
        if (location.hash !== "#" + id) history.replaceState(null, "", "#" + id);
        track("nav", { tab: id });
        if (id === "tab-parcelas") setTimeout(initMap, 50);
        if (id === "tab-satelite") setTimeout(() => { loadTeledeteccion(); }, 50);
        if (id === "tab-resumen") loadResumen();
        if (id === "tab-data") loadDataExplorer();
        if (window.innerWidth < 768) closeSidebar();
      }
      document.querySelectorAll(".nav-btn").forEach((b) =>
        b.addEventListener("click", () => switchTab(b.dataset.tab))
      );

      // ===== Sidebar plegable / responsive =====
      // Estado del sidebar vía clases CSS propias: `is-open` (móvil) / `is-collapsed`
      // (desktop). El CSS (#sidebar) usa la propiedad `transform`, controlada por estas
      // clases, sin chocar con las utilidades translate de Tailwind v4.
      function openSidebar() {
        if (window.innerWidth < 768) {
          $("sidebar").classList.add("is-open");
          $("backdrop").classList.remove("hidden");
        } else {
          $("sidebar").classList.remove("is-collapsed");
          $("main").classList.add("md:ml-72"); $("main").classList.remove("md:ml-0");
          $("btn-reopen").classList.add("hidden");
          $("titlebox").classList.remove("md:pl-12");
        }
      }
      function closeSidebar() {
        $("sidebar").classList.remove("is-open");
        $("backdrop").classList.add("hidden");
        if (window.innerWidth >= 768) {
          $("sidebar").classList.add("is-collapsed");
          $("main").classList.remove("md:ml-72"); $("main").classList.add("md:ml-0");
          $("btn-reopen").classList.remove("hidden");
          $("titlebox").classList.add("md:pl-12");
        }
      }
      $("btn-hamburger").addEventListener("click", openSidebar);
      $("btn-reopen").addEventListener("click", openSidebar);
      $("btn-collapse").addEventListener("click", closeSidebar);
      $("backdrop").addEventListener("click", closeSidebar);
      $("btn-footer").addEventListener("click", () => {
        $("footer-body").classList.toggle("hidden");
        $("footer-chevron").classList.toggle("fa-chevron-up");
        $("footer-chevron").classList.toggle("fa-chevron-down");
      });

      // ===== Parcelas =====
      async function refreshParcels() {
        try {
          const r = await api("/fields");
          parcels = r.ok ? await r.json() : [];
        } catch { parcels = []; }
        const sel = $("select-parcela");
        sel.innerHTML = parcels.length
          ? parcels.map((p) => `<option value="${p.id}">${p.name}</option>`).join("")
          : '<option value="">(sin parcelas)</option>';
        $("parcelas-list").innerHTML = parcels.length
          ? parcels.map((p) => `<li data-pid="${p.id}" title="Ir a la parcela" class="flex items-center justify-between bg-stone-50 border border-stone-200 rounded-lg px-3 py-2 cursor-pointer hover:bg-stone-100"><span class="font-semibold text-stone-700"><i class="fa-solid fa-location-dot text-emerald-600 mr-1"></i>${p.name}</span><i class="fa-solid fa-crosshairs text-stone-400"></i></li>`).join("")
          : '<li class="text-stone-500">Sin parcelas aún.</li>';
        renderParcelsOnMap();
      }
      function initMap() {
        if (map) { map.invalidateSize(); return; }
        const osm = L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", { attribution: "© OpenStreetMap" });
        const sat = L.tileLayer("https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}", { attribution: "© Esri World Imagery", maxZoom: 19 });
        const topo = L.tileLayer("https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png", { attribution: "© OpenTopoMap", maxZoom: 17 });
        map = L.map("map", { center: [-11.37, -77.37], zoom: 11, layers: [sat] }); // Lomas de Lachay
        L.control.layers({ "Satélite": sat, "Normal": osm, "Relieve": topo }).addTo(map);
        drawnItems = new L.FeatureGroup().addTo(map);
        parcelsLayer = L.geoJSON(null, {
          style: { color: "#15803d", weight: 2, fillColor: "#15803d", fillOpacity: 0.15 },
          onEachFeature: (f, layer) => layer.bindPopup(f.properties.name),
        }).addTo(map);
        renderParcelsOnMap();
        const drawControl = new L.Control.Draw({
          draw: { polygon: true, marker: false, polyline: false, circle: false, rectangle: false, circlemarker: false },
          edit: { featureGroup: drawnItems, edit: false, remove: true },
        });
        map.addControl(drawControl);
        map.on(L.Draw.Event.CREATED, (e) => {
          drawnItems.clearLayers(); drawnItems.addLayer(e.layer);
          drawnGeojson = e.layer.toGeoJSON().geometry;
        });
      }
      function renderParcelsOnMap() {
        if (!parcelsLayer) return;
        parcelsLayer.clearLayers();
        const feats = parcels
          .filter((p) => p.geojson)
          .map((p) => ({ type: "Feature", properties: { name: p.name, id: p.id }, geometry: p.geojson }));
        if (!feats.length) return;
        parcelsLayer.addData({ type: "FeatureCollection", features: feats });
        try { map.fitBounds(parcelsLayer.getBounds(), { maxZoom: 14, padding: [25, 25] }); } catch {}
      }
      function flyToParcel(id) {
        const p = parcels.find((x) => x.id === id);
        if (!p || !p.geojson || !map) return;
        try { map.flyToBounds(L.geoJSON(p.geojson).getBounds(), { maxZoom: 15, padding: [25, 25] }); } catch {}
      }
      $("btn-save-parcela").addEventListener("click", async () => {
        const name = $("parcela-name").value.trim();
        if (!drawnGeojson) return notify("Falta el polígono", "Dibuja un polígono en el mapa.");
        if (!name) return notify("Falta el nombre", "Escribe un nombre.");
        try {
          track("parcel_draw_save", { name });
          const r = await api("/fields", { method: "POST", body: JSON.stringify({ name, geojson: drawnGeojson }) });
          if (r.ok) { track("parcel_create", { name }); notify("Parcela guardada", `${name}: backfill NDVI en curso…`); $("parcela-name").value = ""; drawnGeojson = null; drawnItems.clearLayers(); refreshParcels(); }
          else { const e = await r.json().catch(() => ({})); notify("Error " + r.status, e.detail || ""); }
        } catch (e) { notify("Error de red", String(e)); }
      });
      $("btn-demo").addEventListener("click", async () => {
        // Lomas de Lachay (reserva con vegetación estacional → buena variación NDVI)
        const geojson = { type: "Polygon", coordinates: [[[-77.40, -11.40], [-77.40, -11.34], [-77.34, -11.34], [-77.34, -11.40], [-77.40, -11.40]]] };
        try {
          track("parcel_demo");
          const r = await api("/fields", { method: "POST", body: JSON.stringify({ name: "Lomas de Lachay (demo)", geojson }) });
          if (r.ok) { track("parcel_create", { name: "Lomas de Lachay (demo)" }); notify("Parcela demo creada", "Lomas de Lachay: backfill NDVI (5 años) en curso…"); refreshParcels(); }
          else { const e = await r.json().catch(() => ({})); notify("Error " + r.status, e.detail || ""); }
        } catch (e) { notify("Error de red", String(e)); }
      });

      // Click en una parcela de la lista -> volar a su polígono
      $("parcelas-list").addEventListener("click", (e) => {
        const li = e.target.closest("li[data-pid]");
        if (li) { track("parcel_focus", { id: li.dataset.pid }); flyToParcel(li.dataset.pid); }
      });

      // ===== Resumen =====
      async function loadResumen() {
        const fid = $("select-parcela").value;
        const parcel = parcels.find((p) => p.id === fid);
        $("kpi-area").innerText = parcel?.lat != null ? "ver mapa" : "—";
        if (!fid) { $("kpi-ndvi").innerText = "—"; $("kpi-trend").innerText = "—"; return; }
        const r = await api("/ndvi", { method: "POST", body: JSON.stringify({ field_id: fid }) });
        const series = r.ok ? (await r.json()).series : [];
        if (!series.length) { $("kpi-ndvi").innerText = "sin datos"; $("kpi-trend").innerText = "—"; $("resumen-empty").classList.remove("hidden"); return; }
        $("resumen-empty").classList.add("hidden");
        const last = series[series.length - 1].mean_value, delta = last - series[0].mean_value;
        $("kpi-ndvi").innerText = last.toFixed(2);
        $("kpi-trend").innerText = (delta >= 0 ? "+" : "") + delta.toFixed(2);
        const ctx = $("chart-resumen");
        chartResumen?.destroy();
        chartResumen = new Chart(ctx, { type: "line", data: { labels: series.map((p) => p.date), datasets: [{ label: "NDVI", data: series.map((p) => p.mean_value), borderColor: "#15803d", backgroundColor: "rgba(21,128,61,.08)", fill: true, tension: 0.3 }] }, options: { plugins: { legend: { display: false } }, scales: { y: { min: 0, max: 1 } } } });
        track("chart_view", { chart: "resumen", points: series.length });
      }

      // ===== Teledetección (Fase 13: multi-índice) =====
      const INDEX_LABELS = { ndvi: "NDVI", evi: "EVI", savi: "SAVI", ndwi: "NDWI", ndre: "NDRE" };
      const INDEX_RANGES = { ndvi: [0, 1], evi: [0, 1], savi: [-0.4, 0.8], ndwi: [-0.6, 0.7], ndre: [0, 0.5] };
      let currentIndex = "ndvi";
      $("select-index").addEventListener("change", () => {
        currentIndex = $("select-index").value;
        loadTeledeteccion();
      });
      async function loadTeledeteccion() {
        const fid = $("select-parcela").value;
        if (!fid) { $("satelite-empty").classList.remove("hidden"); return; }
        const parcel = parcels.find((p) => p.id === fid);
        const rI = await api("/vegetation/" + currentIndex, { method: "POST", body: JSON.stringify({ field_id: fid }) });
        const series = rI.ok ? (await rI.json()).series : [];
        let weather = [];
        if (parcel?.lat != null) {
          const rW = await api("/weather", { method: "POST", body: JSON.stringify({ lat: parcel.lat, lon: parcel.lon }) });
          weather = rW.ok ? (await rW.json()).series : [];
        }
        if (!series.length && !weather.length) { $("satelite-empty").classList.remove("hidden"); return; }
        $("satelite-empty").classList.add("hidden");
        const label = INDEX_LABELS[currentIndex] || currentIndex.toUpperCase();
        const range = INDEX_RANGES[currentIndex] || [0, 1];
        chartSatelite?.destroy();
        chartSatelite = new Chart($("chart-satelite"), {
          data: {
            labels: series.map((p) => p.date),
            datasets: [
              { type: "line", label: label, data: series.map((p) => p.mean_value), borderColor: "#15803d", yAxisID: "y", tension: 0.3 },
              { type: "bar", label: "Precip (mm)", data: weather.map((p) => p.precip_mm), backgroundColor: "rgba(59,130,246,.6)", yAxisID: "y2" },
            ],
          },
          options: { scales: { y: { position: "left", min: range[0], max: range[1], title: { display: true, text: label } }, y2: { position: "right", grid: { drawOnChartArea: false }, title: { display: true, text: "mm" } } } },
        });
        track("chart_view", { chart: "teledeteccion", index: currentIndex, points: series.length, weather: weather.length });
      }
      $("btn-heatmap").addEventListener("click", async () => {
        const fid = $("select-parcela").value;
        if (!fid) return notify("Selecciona una parcela", "");
        const idx = currentIndex;
        track("heatmap", { field_id: fid, index: idx });
        $("heatmap-box").innerHTML = '<span class="text-xs text-stone-500">Generando…</span>';
        try {
          const r = await api("/vegetation/" + idx + "/raster", { method: "POST", body: JSON.stringify({ field_id: fid }) });
          if (r.ok) { const url = URL.createObjectURL(await r.blob()); $("heatmap-box").innerHTML = `<img src="${url}" class="max-w-full rounded" />`; }
          else { $("heatmap-box").innerHTML = '<span class="text-xs text-red-500">No se pudo generar (¿Copernicus en Credenciales?).</span>'; }
        } catch (e) { $("heatmap-box").innerHTML = '<span class="text-xs text-red-500">Error de red.</span>'; }
      });

      // ===== Reprocesar (SF13.1) =====
      function showReprocessModal() {
        const fid = $("select-parcela").value;
        if (!fid) return notify("Selecciona una parcela", "");
        $("reprocess-modal").classList.remove("hidden");
        $("reprocess-modal").classList.add("flex");
        $("reprocess-status").classList.add("hidden");
        $("reprocess-status").innerText = "";
        track("reprocess_modal_open", { field_id: fid });
      }
      function closeReprocessModal() {
        $("reprocess-modal").classList.add("hidden");
        $("reprocess-modal").classList.remove("flex");
      }
      $("btn-reprocess").addEventListener("click", showReprocessModal);
      $("btn-close-reprocess").addEventListener("click", closeReprocessModal);
      $("btn-cancel-reprocess").addEventListener("click", closeReprocessModal);
      $("reprocess-modal").addEventListener("click", (e) => { if (e.target === e.currentTarget) closeReprocessModal(); });
      $("btn-run-reprocess").addEventListener("click", async () => {
        const fid = $("select-parcela").value;
        const mode = document.querySelector('input[name="reprocess-mode"]:checked')?.value || "all";
        const btn = $("btn-run-reprocess");
        btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Procesando…';
        $("reprocess-status").classList.remove("hidden");
        $("reprocess-status").innerText = "Reprocesando… esto puede tomar varios minutos.";
        track("reprocess_start", { field_id: fid, mode });
        try {
          const r = await api("/vegetation/reprocess", { method: "POST", body: JSON.stringify({ field_id: fid, mode }) });
          if (r.ok) {
            const data = await r.json();
            const idxCount = data.indices?.length || 0;
            const totalPoints = data.indices?.reduce((s, i) => s + i.points, 0) || 0;
            $("reprocess-status").innerText = `Reproceso completado: ${idxCount} índices, ${totalPoints} puntos.${data.weather ? " Clima actualizado." : ""}`;
            $("reprocess-status").className = "mt-3 text-xs text-emerald-600";
            track("reprocess_done", { field_id: fid, mode, indices: idxCount, points: totalPoints });
            setTimeout(() => { closeReprocessModal(); loadTeledeteccion(); }, 1500);
          } else {
            const err = await r.json().catch(() => ({}));
            $("reprocess-status").innerText = "Error: " + (err.detail || r.status);
            $("reprocess-status").className = "mt-3 text-xs text-red-600";
            track("reprocess_error", { field_id: fid, mode, status: r.status });
          }
        } catch (e) {
          $("reprocess-status").innerText = "Error de red: " + e;
          $("reprocess-status").className = "mt-3 text-xs text-red-600";
        } finally {
          btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-play"></i> Ejecutar';
        }
      });

      // ===== Chat =====
      function appendChat(who, text, tools) {
        const div = document.createElement("div");
        const mine = who === "user";
        div.className = "p-3 rounded-lg border max-w-[85%] " + (mine ? "bg-white border-stone-200 ml-auto" : "bg-stone-900 text-stone-100 border-stone-800");
        div.innerHTML = `<p class="font-bold text-[10px] uppercase mb-1 ${mine ? "text-stone-500" : "text-emerald-400"}">${mine ? "🧑 Tú" : "🤖 AgroVisión AI"}${tools && tools.length ? " · " + tools.join(", ") : ""}</p><p class="leading-relaxed">${text}</p>`;
        $("chat-history").appendChild(div); $("chat-history").scrollTop = 1e9;
      }
      async function sendChat() {
        const msg = $("chat-input").value.trim(); if (!msg) return;
        track("chat_send", { len: msg.length });
        appendChat("user", msg); $("chat-input").value = "";
        try {
          const r = await api("/chat", { method: "POST", body: JSON.stringify({ session_id: sessionId, message: msg }) });
          if (r.ok) { const d = await r.json(); appendChat("assistant", d.reply, (d.tool_logs || []).map((t) => t.tool)); }
          else { const e = await r.json().catch(() => ({})); appendChat("assistant", "Error: " + (e.detail || r.status)); }
        } catch (e) { appendChat("assistant", "Error de red: " + e); }
      }
      $("btn-chat").addEventListener("click", sendChat);
      $("chat-input").addEventListener("keydown", (e) => { if (e.key === "Enter") sendChat(); });

      // ===== Telemetría Modal (Fase 12) =====
      function openTelemetryModal() {
        $("telemetry-modal").classList.remove("hidden");
        $("telemetry-modal").classList.add("flex");
        $("telemetry-session-id").innerText = sessionId;
        loadTelemetryEvents();
        track("telemetry_open", {});
      }
      function closeTelemetryModal() {
        $("telemetry-modal").classList.add("hidden");
        $("telemetry-modal").classList.remove("flex");
      }
      async function loadTelemetryEvents() {
        const content = $("telemetry-content");
        content.innerHTML = '<p class="text-xs text-stone-500">Cargando eventos...</p>';
        try {
          // Intentar primero eventos persistentes (BD)
          let events = [];
          try {
            const r = await api("/events/all?limit=200");
            if (r.ok) {
              events = await r.json();
            }
          } catch {}
          // Si no hay eventos en BD, usar buffer en memoria
          if (!events || events.length === 0) {
            try {
              const r2 = await api("/events/recent?limit=200");
              if (r2.ok) {
                events = await r2.json();
              }
            } catch {}
          }
          if (!events || events.length === 0) {
            content.innerHTML = '<p class="text-xs text-stone-500">Sin eventos en esta sesión. Interactúa con la UI para generar eventos.</p>';
            return;
          }
          renderTelemetryEvents(events, content);
        } catch (e) {
          content.innerHTML = `<p class="text-xs text-red-500">Error al cargar eventos: ${e}</p>`;
        }
      }
      function renderTelemetryEvents(events, container) {
        const html = events.map((ev) => {
          const ts = ev.created_at || ev.ts || "";
          const time = ts ? new Date(ts).toLocaleTimeString() : "";
          const isError = ev.action.includes("error");
          const bg = isError ? "bg-red-50 border-red-200" : "bg-stone-50 border-stone-200";
          const icon = isError ? "fa-circle-exclamation text-red-500" : "fa-circle-dot text-emerald-500";
          const metaStr = ev.meta && Object.keys(ev.meta).length ? JSON.stringify(ev.meta).slice(0, 120) : "";
          return `<div class="border ${bg} rounded-lg px-3 py-2 text-[10px]">
            <div class="flex items-center gap-2 mb-1">
              <i class="fa-solid ${icon}"></i>
              <span class="font-bold text-stone-700">${ev.action}</span>
              <span class="text-stone-400 ml-auto">${time}</span>
            </div>
            ${metaStr ? `<div class="text-stone-500 font-mono truncate">${metaStr}</div>` : ""}
          </div>`;
        }).join("");
        container.innerHTML = html;
      }
      $("btn-telemetry").addEventListener("click", openTelemetryModal);
      $("btn-close-telemetry").addEventListener("click", closeTelemetryModal);
      $("btn-refresh-telemetry").addEventListener("click", loadTelemetryEvents);
      $("telemetry-modal").addEventListener("click", (e) => { if (e.target === $("telemetry-modal")) closeTelemetryModal(); });

      // ===== Explorador de Datos (Fase 11) =====
      const TABLES = ["fields", "vegetation_indices", "ndvi_timeseries", "chat_messages", "events"];
      async function loadDataExplorer() {
        loadSchema();
        const list = $("tables-list");
        list.innerHTML = TABLES.map((t) =>
          `<button data-table="${t}" class="w-full text-left text-xs px-3 py-2 rounded-lg border border-stone-200 bg-stone-50 hover:bg-stone-100 font-semibold text-stone-700"><i class="fa-solid fa-table mr-1 text-emerald-600"></i>${t}</button>`
        ).join("");
        list.querySelectorAll("button").forEach((b) =>
          b.addEventListener("click", () => loadTableData(b.dataset.table))
        );
      }
      async function loadSchema() {
        const el = $("er-diagram");
        try {
          const r = await api("/data/schema");
          if (!r.ok) { el.innerHTML = '<p class="text-xs text-stone-500">Error al cargar esquema.</p>'; return; }
          const d = await r.json();
          const tables = d.tables || {};
          const shortType = (t) => {
            if (t.includes("timestamp")) return "timestamptz";
            if (t.includes("double")) return "float";
            if (t === "USER-DEFINED") return "geometry";
            return t;
          };
          let mmd = "erDiagram\n";
          for (const [name, cols] of Object.entries(tables)) {
            mmd += `  ${name} {\n`;
            for (const c of cols) {
              const ann = c.name === "id" ? " PK" : c.name.endsWith("_id") ? " FK" : "";
              mmd += `    ${shortType(c.type)} ${c.name}${ann}\n`;
            }
            mmd += "  }\n";
          }
          mmd += '  fields ||--o{ vegetation_indices : "tiene"\n';
          mmd += '  fields ||--o{ ndvi_timeseries : "legacy"\n';
          mmd += '  fields ||--o{ plant_counts : "tiene"\n';
          mmd += '  fields ||--o{ events : "genera"\n';
          mmd += '  fields ||--o{ chat_messages : "genera"\n';
          const id = "er-" + Date.now();
          const { svg } = await mermaid.render(id, mmd);
          el.innerHTML = svg;
        } catch (e) {
          el.innerHTML = '<p class="text-xs text-red-500">Error al renderizar diagrama ER: ' + String(e?.message || e) + '</p>';
        }
      }
      async function loadTableData(table) {
        $("data-view-title").innerText = `Tabla: ${table}`;
        $("data-view-content").innerHTML = '<p class="text-xs text-stone-500">Cargando...</p>';
        try {
          const r = await api(`/data/${table}`);
          if (!r.ok) { $("data-view-content").innerHTML = '<p class="text-xs text-red-500">Error al cargar. Verifica credenciales.</p>'; return; }
          const d = await r.json();
          const rows = d.rows || [];
          $("data-view-count").innerText = `${rows.length} registros`;
          if (!rows.length) { $("data-view-content").innerHTML = '<p class="text-xs text-stone-500">Sin registros.</p>'; return; }
          const cols = Object.keys(rows[0]);
          const html = `<table class="w-full text-[10px] border-collapse"><thead><tr>${cols.map((c) => `<th class="border border-stone-200 px-2 py-1 bg-stone-100 font-bold text-stone-700">${c}</th>`).join("")}</tr></thead><tbody>${rows.map((row) => `<tr>${cols.map((c) => `<td class="border border-stone-200 px-2 py-1">${formatCell(row[c])}</td>`).join("")}</tr>`).join("")}</tbody></table>`;
          $("data-view-content").innerHTML = html;
        } catch (e) { $("data-view-content").innerHTML = `<p class="text-xs text-red-500">Error: ${e}</p>`; }
      }
      function formatCell(v) {
        if (v === null || v === undefined) return '<span class="text-stone-400">NULL</span>';
        if (typeof v === "object") return `<code class="text-[9px] bg-stone-100 px-1 rounded">${JSON.stringify(v).slice(0, 80)}</code>`;
        return String(v).slice(0, 100);
      }
      $("btn-run-query").addEventListener("click", async () => {
        const sql = $("sql-query").value.trim();
        if (!sql) return notify("Falta la consulta", "Escribe una consulta SQL.");
        $("query-result").innerHTML = '<p class="text-xs text-stone-500">Ejecutando...</p>';
        try {
          const r = await api("/data/query", { method: "POST", body: JSON.stringify({ sql }) });
          if (!r.ok) { const e = await r.json().catch(() => ({})); $("query-result").innerHTML = `<p class="text-xs text-red-500">Error: ${e.detail || r.status}</p>`; return; }
          const d = await r.json();
          const rows = d.rows || [];
          if (!rows.length) { $("query-result").innerHTML = '<p class="text-xs text-stone-500">Sin resultados.</p>'; return; }
          const cols = Object.keys(rows[0]);
          const html = `<table class="w-full text-[10px] border-collapse"><thead><tr>${cols.map((c) => `<th class="border border-stone-200 px-2 py-1 bg-stone-100 font-bold text-stone-700">${c}</th>`).join("")}</tr></thead><tbody>${rows.map((row) => `<tr>${cols.map((c) => `<td class="border border-stone-200 px-2 py-1">${formatCell(row[c])}</td>`).join("")}</tr>`).join("")}</tbody></table>`;
          $("query-result").innerHTML = html;
        } catch (e) { $("query-result").innerHTML = `<p class="text-xs text-red-500">Error: ${e}</p>`; }
      });
      $("btn-clear-query").addEventListener("click", () => { $("sql-query").value = ""; $("query-result").innerHTML = ""; });

      // ===== Credenciales (efímeras) =====
      $("btn-save-creds").addEventListener("click", () => {
        creds = { groq: $("in-groq").value, copId: $("in-copid").value, copSecret: $("in-copsecret").value, sbUrl: $("in-sburl").value, sbKey: $("in-sbkey").value };
        const n = Object.values(creds).filter(Boolean).length;
        track("creds_set", { count: n });  // ¡solo el número de llaves, nunca los valores!
        $("creds-state").innerText = `${n} llave(s) activas (se borran al refrescar)`;
        notify("Credenciales en sesión", `${n} llave(s) activas solo en esta sesión.`);
        updateStatus();
        refreshParcels();
      });
      $("btn-check-env").addEventListener("click", async () => {
        try {
          const r = await fetch("./api/credentials/status");
          if (!r.ok) return notify("No disponible", "No se pudo consultar el .env del servidor.");
          const s = await r.json();
          appEnv = s.env || "development";
          const have = Object.entries({ Groq: s.groq, Copernicus: s.copernicus, Supabase: s.supabase }).filter(([, v]) => v).map(([k]) => k);
          track("env_check", { have, env: appEnv });
          if (appEnv === "production") {
            $("env-status").innerHTML = " <b>Producción:</b> cada usuario debe ingresar sus propias credenciales.";
          } else {
            $("env-status").innerHTML = have.length
              ? `✅ En el servidor (.env): <b>${have.join(", ")}</b>. Se usan automáticamente; no necesitas reescribirlas aquí.`
              : "No se detectaron credenciales en el .env del servidor.";
          }
        } catch { notify("Error", "No se pudo consultar el .env del servidor."); }
      });

      // ===== Init =====
      $("select-parcela").addEventListener("change", () => {
        const active = document.querySelector(".tab-content.active")?.id;
        if (active === "tab-satelite") loadTeledeteccion();
        else loadResumen();
      });
      (async function init() {
        track("session_start", { w: window.innerWidth, h: window.innerHeight });
        try {
          const r = await fetch("./api/status");
          backendOk = r.ok;
          $("db-status-text").innerText = backendOk ? "Backend conectado" : "Backend no disponible";
          if (backendOk) { $("db-status-text").classList.replace("text-stone-400", "text-emerald-400"); }
        } catch { $("db-status-text").innerText = "Backend no disponible"; }
        updateStatus();
        // Detectar entorno y mostrar aviso si es producción
        try {
          const r = await fetch("./api/credentials/status");
          if (r.ok) {
            const s = await r.json();
            appEnv = s.env || "development";
            if (appEnv === "production") {
              $("creds-production-warning").classList.remove("hidden");
              $("btn-check-env").style.display = "none";
            }
          }
        } catch {}
        await refreshParcels();
        const initial = (location.hash || "#tab-resumen").slice(1);
        switchTab(document.getElementById(initial) ? initial : "tab-resumen");
        loadResumen();
      })();
    </script>
  </body>
</html>
